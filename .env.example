# profile-service — prod env (set in the platform dashboard)
SPRING_PROFILES_ACTIVE=prod

DB_URL=jdbc:postgresql://<host>:6543/postgres?currentSchema=profile_svc
DB_USERNAME=
DB_PASSWORD=
DB_POOL_SIZE=5

JWKS_URI=https://<user-service-url>/.well-known/jwks.json

# Public SPA origin the QR/share links point at Vercel URL
WEB_PUBLIC_URL=https://<app>.vercel.app

AVATAR_BUCKET=beamcard-avatars
AVATAR_REGION=<supabase-region>
AVATAR_ENDPOINT=https://<project>.supabase.co/storage/v1/s3
AVATAR_ACCESS_KEY=
AVATAR_SECRET_KEY=
AVATAR_PATH_STYLE=true
AVATAR_ENSURE_BUCKET=false
AVATAR_PUBLIC_BASE_URL=https://<project>.supabase.co/storage/v1/object/public/beamcard-avatars

JAVA_TOOL_OPTIONS=-XX:MaxRAMPercentage=75
